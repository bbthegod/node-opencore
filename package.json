{
  "name": "node-opencore",
  "version": "2.0.0",
  "description": "Node OpenCore",
  "author": "https://github.com/bbthegod",
  "main": "index.js",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bbthegod/node-opencore.git"
  },
  "engines": {
    "npm": ">=6.14.6",
    "node": ">=12.18.4",
    "yarn": ">=1.22.10"
  },
  "pre-commit": "lint:staged",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "npm run eslint -- --fix"
    ],
    "*.{md,json}": [
      "prettier --write"
    ]
  },
  "scripts": {
    "start": "nodemon src/index.js",
    "generate": "plop --plopfile internals/generators/index.js",
    "lint": "eslint . --ext .js",
    "prettify": "prettier --write ."
  },
  "dependencies": {
    "bcrypt": "^5.0.0",
    "bluebird": "3.7.2",
    "body-parser": "1.19.0",
    "compression": "1.7.4",
    "cookie-parser": "1.4.5",
    "cors": "2.8.5",
    "dotenv": "^8.2.0",
    "express": "4.17.1",
    "express-bearer-token": "^2.4.0",
    "express-validation": "3.0.6",
    "helmet": "4.1.1",
    "http-status": "1.4.2",
    "joi": "17.2.1",
    "jsonwebtoken": "^8.5.1",
    "method-override": "^3.0.0",
    "mongoose": "5.10.9",
    "morgan": "^1.10.0",
    "shelljs": "^0.8.4"
  },
  "devDependencies": {
    "eslint": "^7.11.0",
    "eslint-config-airbnb-base": "^14.2.0",
    "eslint-plugin-import": "^2.22.1",
    "plop": "false2.4.0",
    "prettier": "2.1.2"
  }
}
